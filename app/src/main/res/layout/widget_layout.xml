<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:text="🗓️ TAMIL CALENDAR"
        android:layout_marginBottom="6dp" />

    <!-- Two-column Middle Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Left Column: English Date details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_english_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:text="17" />

            <TextView
                android:id="@+id/widget_day_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B0BEC5"
                android:textSize="10sp"
                android:textStyle="bold"
                android:text="FRIDAY" />

            <TextView
                android:id="@+id/widget_month_year"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B0BEC5"
                android:textSize="10sp"
                android:text="July 2026" />
        </LinearLayout>

        <!-- Divider Line -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#40FFFFFF"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <!-- Right Column: Tamil Date details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1.2"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_tamil_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFF6B00"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="ஆடி 3 / Aadi 3" />

            <TextView
                android:id="@+id/widget_nakshatra"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#CE93D8"
                android:textSize="12sp"
                android:text="⭐ Hastam"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Info / Alerts / Reminders -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/widget_moon_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E0E0E0"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:text="🌕 Pournami Today" />

        <TextView
            android:id="@+id/widget_reminder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#90CAF9"
            android:textSize="11sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="1dp"
            android:text="🔔 Chit Payment Tomorrow" />
    </LinearLayout>

</LinearLayout>
